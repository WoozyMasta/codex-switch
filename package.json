{
  "name": "codex-switch",
  "author": "WoozyMasta",
  "repository": {
    "type": "git",
    "url": "https://github.com/WoozyMasta/codex-switch"
  },
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.3.2",
  "license": "MIT",
  "publisher": "woozy-masta",
  "files": [
    "out/**",
    "resources/**",
    "l10n/**",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.nls*.json"
  ],
  "scripts": {
    "vscode:prepublish": "npm run build:package",
    "build": "node ./scripts/clean-build-output.mjs && tsc -p ./",
    "build:package": "node ./scripts/clean-build-output.mjs && tsc -p ./ --sourceMap false",
    "build:test": "node ./scripts/clean-test-output.mjs && tsc -p ./tsconfig.test.json",
    "lint:ts": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\" \"!.vscode-test/**\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:ts && npm run lint:md && npm run format:check",
    "test:unit": "npm run build:test && node ./scripts/run-node-tests.mjs",
    "test:coverage": "npm run build:test && node ./scripts/run-node-tests.mjs --coverage",
    "test:integration": "npm run build:test && vscode-test",
    "check": "npm run build && npm run lint && npm run test:unit && npm run test:coverage",
    "check:release": "npm run check && npm run test:integration",
    "vscode:package": "vsce package",
    "vscode:publish": "vsce publish",
    "openvsx:publish": "npx ovsx publish",
    "watch": "tsc -watch -p ./"
  },
  "engines": {
    "vscode": "^1.105.1",
    "node": ">=24 <25"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/codex-switch.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "codex-switch.login",
        "title": "%command.login.title%"
      },
      {
        "command": "codex-switch.profile.manage",
        "title": "%command.profile.manage.title%"
      },
      {
        "command": "codex-switch.profile.login",
        "title": "%command.profile.login.title%"
      },
      {
        "command": "codex-switch.profile.switch",
        "title": "%command.profile.switch.title%"
      },
      {
        "command": "codex-switch.profile.toggleLast",
        "title": "%command.profile.toggleLast.title%"
      },
      {
        "command": "codex-switch.profile.addFromCodexAuthFile",
        "title": "%command.profile.addFromCodexAuthFile.title%"
      },
      {
        "command": "codex-switch.profile.prepareForNewLoginChat",
        "title": "%command.profile.prepareForNewLoginChat.title%"
      },
      {
        "command": "codex-switch.profile.addFromFile",
        "title": "%command.profile.addFromFile.title%"
      },
      {
        "command": "codex-switch.profile.exportSettings",
        "title": "%command.profile.exportSettings.title%"
      },
      {
        "command": "codex-switch.profile.importSettings",
        "title": "%command.profile.importSettings.title%"
      },
      {
        "command": "codex-switch.profile.rename",
        "title": "%command.profile.rename.title%"
      },
      {
        "command": "codex-switch.profile.delete",
        "title": "%command.profile.delete.title%"
      },
      {
        "command": "codex-switch.profile.syncFromDefaultHome",
        "title": "%command.profile.syncFromDefaultHome.title%"
      }
    ],
    "menus": {
      "statusBar/item/context": [
        {
          "command": "codex-switch.profile.manage",
          "when": "statusBarItemId == codex-switch.profile",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "codexSwitch.debugLogging": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.debugLogging.description%"
        },
        "codexSwitch.activeProfileScope": {
          "type": "string",
          "enum": [
            "global",
            "workspace"
          ],
          "default": "global",
          "description": "%configuration.activeProfileScope.description%"
        },
        "codexSwitch.storageMode": {
          "type": "string",
          "enum": [
            "auto",
            "secretStorage",
            "remoteFiles"
          ],
          "default": "auto",
          "description": "%configuration.storageMode.description%"
        },
        "codexSwitch.reloadWindowAfterProfileSwitch": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.reloadWindowAfterProfileSwitch.description%"
        },
        "codexSwitch.codexCliPath": {
          "type": "string",
          "default": "",
          "description": "%configuration.codexCliPath.description%"
        },
        "codexSwitch.rateLimitAutoRefreshIntervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "%configuration.rateLimitAutoRefreshIntervalSeconds.description%"
        },
        "codexSwitch.statusBarClickBehavior": {
          "type": "string",
          "enum": [
            "cycle",
            "toggleLast",
            "selector"
          ],
          "default": "cycle",
          "description": "%configuration.statusBarClickBehavior.description%",
          "enumDescriptions": [
            "%configuration.statusBarClickBehavior.cycle%",
            "%configuration.statusBarClickBehavior.toggleLast%",
            "%configuration.statusBarClickBehavior.selector%"
          ]
        },
        "codexSwitch.codexHome.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.codexHome.enabled.description%"
        },
        "codexSwitch.codexHome.inheritDefaultProfileWhenEmpty": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.codexHome.inheritDefaultProfileWhenEmpty.description%"
        }
      }
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "24.x",
    "@types/vscode": "^1.105.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vsce": "^2.15.0"
  }
}
